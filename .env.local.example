# Google Sheet 연동 (서비스 계정 / 읽기 전용)
# 자세한 발급 방법은 README.md 참고

# 스프레드시트 URL의 /d/<ID>/edit 부분
GOOGLE_SHEET_ID=

# 서비스 계정 JSON 의 client_email
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# 서비스 계정 JSON 의 private_key (따옴표로 감싸고, \n 그대로 두기)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
